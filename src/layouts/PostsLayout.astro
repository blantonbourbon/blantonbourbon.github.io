---
import { getPostCatalog } from '@utils/content'
import { formatDateYMD } from '@utils/format'
import { useLocale } from '@utils/locale'
import Layout from '../layouts/Layout.astro'

const { t, locale: urlLocale } = useLocale(Astro.url)
const { tag, locale: propsLocale } = Astro.props
const locale = propsLocale || urlLocale || 'zh'
const { posts, activeTag } = await getPostCatalog(locale, { tag })

const filterName = activeTag?.labelKey
---

<Layout title={t("nav.posts")}>
  {
    filterName && (
      <div class="mt-2">
        <span class="text-xl font-bold italic ml-2">
          " {t(filterName)} "
        </span>
      </div>
    )
  }
  <main class="mt-8">
    <ul class="list-none pl-0">
      {
        posts.map((post) => {
          return (
            <li class="my-4">
              <div class="flex flex-nowrap">
                <span
                  style={{ flex: "0 0 10rem" }}
                  class="text-gray-500 whitespace-nowrap"
                >
                  <time class="mr-8 italic">{formatDateYMD(post.date)}</time>
                </span>
                <span class="flex-1 truncate">
                  <a href={post.url} class="link-static">
                    {post.displayTitle}
                  </a>
                </span>
              </div>
            </li>
          );
        })
      }
    </ul>


  </main>
</Layout>
